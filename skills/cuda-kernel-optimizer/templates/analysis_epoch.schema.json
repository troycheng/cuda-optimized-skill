{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v3.1/analysis-epoch.json",
  "title": "CUDA optimizer V3.1 Controller-owned analysis epoch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "epoch_id",
    "sequence",
    "trigger",
    "parent_epoch_id",
    "started_at",
    "identities",
    "source",
    "regime",
    "boundary_ambiguous"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/analysis-epoch-v1"},
    "epoch_id": {"$ref": "#/$defs/identifier"},
    "sequence": {"type": "integer", "minimum": 1},
    "trigger": {
      "enum": [
        "initial",
        "mechanism_change",
        "workload_regime_change",
        "bottleneck_migration",
        "identity_change",
        "conservative_boundary"
      ]
    },
    "parent_epoch_id": {
      "oneOf": [{"$ref": "#/$defs/identifier"}, {"type": "null"}]
    },
    "started_at": {"type": "number", "minimum": 0},
    "identities": {"$ref": "#/$defs/identities"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profiler",
        "profiler_version",
        "export_schema",
        "adapter_id",
        "adapter_version",
        "adapter_sha256"
      ],
      "properties": {
        "profiler": {"enum": ["nsys", "pytorch", "perfetto", "custom"]},
        "profiler_version": {"type": "string", "minLength": 1, "maxLength": 256},
        "export_schema": {"type": "string", "minLength": 1, "maxLength": 256},
        "adapter_id": {"$ref": "#/$defs/identifier"},
        "adapter_version": {"type": "string", "minLength": 1, "maxLength": 256},
        "adapter_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shape_distribution_sha256",
        "dynamic_branch_sha256",
        "execution_regime_sha256"
      ],
      "properties": {
        "shape_distribution_sha256": {"$ref": "#/$defs/sha256"},
        "dynamic_branch_sha256": {"$ref": "#/$defs/sha256"},
        "execution_regime_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "boundary_ambiguous": {"type": "boolean"}
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload_contract_sha256",
        "environment_sha256",
        "source_sha256",
        "analysis_policy_sha256"
      ],
      "properties": {
        "workload_contract_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "analysis_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

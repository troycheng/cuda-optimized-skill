{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v2.5/serving-experiment.json",
  "title": "CUDA optimizer V2.5 serving experiment and objective",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocols", "fresh_process_per_role", "request_corpus_sha256", "strata"],
  "properties": {
    "schema_version": {"const": "cuda-evidence/serving-experiment-v1"},
    "protocols": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["http", "grpc"]}},
    "fresh_process_per_role": {"const": true},
    "request_corpus_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "strata": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "protocol", "concurrency", "warmup_requests", "measured_requests", "metrics", "must_pass"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "protocol": {"enum": ["http", "grpc"]},
          "concurrency": {"enum": [1, 2, 4, 8, 12]},
          "warmup_requests": {"type": "integer", "minimum": 1},
          "measured_requests": {"type": "integer", "minimum": 1},
          "metrics": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["qps", "avg_latency_ms", "p95_latency_ms", "p99_latency_ms", "server_input_ms", "server_infer_ms", "server_output_ms"]}
          },
          "must_pass": {
            "type": "object",
            "additionalProperties": false,
            "required": ["relative", "absolute"],
            "properties": {
              "relative": {"type": "array", "minItems": 1},
              "absolute": {"type": "array", "minItems": 1}
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v3.1/hypothesis-set.json",
  "title": "CUDA optimizer V3.1 competing hypothesis set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "set_id",
    "epoch_id",
    "epoch_sha256",
    "execution_map_sha256",
    "hypotheses",
    "relationships"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/hypothesis-set-v1"},
    "set_id": {"$ref": "#/$defs/identifier"},
    "epoch_id": {"$ref": "#/$defs/identifier"},
    "epoch_sha256": {"$ref": "#/$defs/sha256"},
    "execution_map_sha256": {"$ref": "#/$defs/sha256"},
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"$ref": "#/$defs/hypothesis"}
    },
    "relationships": {
      "type": "array",
      "maxItems": 66,
      "items": {"$ref": "#/$defs/relationship"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identifier_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis_id",
        "kind",
        "scope_node_ids",
        "statement",
        "mechanism",
        "disposition",
        "confidence",
        "support_evidence_ids",
        "oppose_evidence_ids",
        "missing_evidence_kinds",
        "falsification_question"
      ],
      "properties": {
        "hypothesis_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["mechanism", "unmodeled"]},
        "scope_node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "statement": {"type": "string", "minLength": 1, "maxLength": 1024},
        "mechanism": {"$ref": "#/$defs/identifier"},
        "disposition": {"enum": ["active", "rejected", "undifferentiable"]},
        "confidence": {"enum": ["inconclusive", "plausible", "direction_supported"]},
        "support_evidence_ids": {"$ref": "#/$defs/identifier_array"},
        "oppose_evidence_ids": {"$ref": "#/$defs/identifier_array"},
        "missing_evidence_kinds": {"$ref": "#/$defs/identifier_array"},
        "falsification_question": {"type": "string", "minLength": 1, "maxLength": 1024}
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation", "left", "right"],
      "properties": {
        "relation": {"enum": ["exclusive", "depends_on", "coexists_with"]},
        "left": {"$ref": "#/$defs/identifier"},
        "right": {"$ref": "#/$defs/identifier"}
      }
    }
  }
}

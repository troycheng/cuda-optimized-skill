{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/planner_admission.schema.json",
  "title": "CUDA optimizer Planner admission v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "run_id", "ledger_id", "contract_sha256",
    "environment_sha256", "candidate_id", "mechanism_id", "observation_id",
    "observation_summary_sha256", "capability_query_sha256", "capability_ids",
    "admitted_at", "evidence_age_seconds", "pre_execution", "admission_sha256",
    "controller_attestation"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/planner-admission-v1"},
    "status": {"const": "ADMITTED"},
    "run_id": {"$ref": "#/$defs/identifier"},
    "ledger_id": {"$ref": "#/$defs/identifier"},
    "contract_sha256": {"$ref": "#/$defs/sha256"},
    "environment_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_id": {"$ref": "#/$defs/identifier"},
    "mechanism_id": {"$ref": "#/$defs/identifier"},
    "observation_id": {"$ref": "#/$defs/identifier"},
    "observation_summary_sha256": {"$ref": "#/$defs/sha256"},
    "capability_query_sha256": {"$ref": "#/$defs/sha256"},
    "capability_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "admitted_at": {"type": "number", "minimum": 0},
    "evidence_age_seconds": {"type": "number", "minimum": 0},
    "pre_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["satisfied", "missing_gates", "gates"],
      "properties": {
        "satisfied": {"const": true},
        "missing_gates": {"type": "array", "maxItems": 0},
        "gates": {
          "type": "array", "minItems": 3, "maxItems": 3,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["gate", "satisfied", "observation_ids", "artifact_sha256s"],
            "properties": {
              "gate": {"enum": ["correctness_reference", "dispatch_identity", "target_compile_probe"]},
              "satisfied": {"const": true},
              "observation_ids": {
                "type": "array", "minItems": 1, "uniqueItems": true,
                "items": {"$ref": "#/$defs/identifier"}
              },
              "artifact_sha256s": {
                "type": "array", "minItems": 1, "uniqueItems": true,
                "items": {"$ref": "#/$defs/sha256"}
              }
            }
          }
        }
      }
    },
    "admission_sha256": {"$ref": "#/$defs/sha256"},
    "controller_attestation": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"}
  }
}

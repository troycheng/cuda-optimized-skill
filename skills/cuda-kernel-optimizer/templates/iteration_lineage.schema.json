{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schema/v2.6/iteration-lineage.json",
  "title": "Frozen performance-iteration lineage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_source_sha256",
    "environment_sha256",
    "measurement_paths",
    "initial_measurement_path"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/iteration-lineage-v1"},
    "baseline_source_sha256": {"$ref": "#/$defs/sha256"},
    "environment_sha256": {"$ref": "#/$defs/sha256"},
    "measurement_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/pathIdentity"}
    },
    "initial_measurement_path": {"$ref": "#/$defs/pathIdentity"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonempty": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
    "pathIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "definition_sha256"],
      "properties": {
        "id": {"$ref": "#/$defs/nonempty"},
        "version": {"$ref": "#/$defs/nonempty"},
        "definition_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v3.1/active-diagnosis-contract.json",
  "title": "CUDA optimizer V3.1 active diagnosis contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "global_scan_probe_id",
    "adapter_path",
    "analysis_policy_sha256",
    "source",
    "actions",
    "selection_policy"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/active-diagnosis-contract-v1"},
    "global_scan_probe_id": {"$ref": "#/$defs/id"},
    "adapter_path": {"type": "string", "minLength": 1},
    "analysis_policy_sha256": {"$ref": "#/$defs/sha256"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profiler",
        "profiler_version",
        "export_schema",
        "adapter_id",
        "adapter_version",
        "adapter_sha256"
      ],
      "properties": {
        "profiler": {"enum": ["nsys", "pytorch", "perfetto", "custom"]},
        "profiler_version": {"type": "string", "minLength": 1},
        "export_schema": {"type": "string", "minLength": 1},
        "adapter_id": {"$ref": "#/$defs/id"},
        "adapter_version": {"type": "string", "minLength": 1},
        "adapter_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/action"}
    },
    "selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "max_cost",
        "max_perturbation",
        "max_risk",
        "remaining_profile_actions",
        "available_capability_ids"
      ],
      "properties": {
        "schema_version": {"const": "cuda-optimizer/evidence-selection-policy-v1"},
        "max_cost": {"$ref": "#/$defs/level"},
        "max_perturbation": {"$ref": "#/$defs/level"},
        "max_risk": {"$ref": "#/$defs/level"},
        "remaining_profile_actions": {"type": "integer", "minimum": 0},
        "available_capability_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"},
          "description": "Accepted for compatibility; Controller replaces it with current readiness evidence"
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "level": {"enum": ["none", "low", "medium", "high"]},
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "adapter_path",
        "adapter_sha256",
        "argv",
        "timeout_seconds"
      ],
      "properties": {
        "action_id": {"$ref": "#/$defs/id"},
        "adapter_path": {"type": "string", "minLength": 1},
        "adapter_sha256": {"$ref": "#/$defs/sha256"},
        "argv": {"$ref": "#/$defs/argv"},
        "timeout_seconds": {"type": "number", "minimum": 1, "maximum": 3600}
      }
    }
  }
}

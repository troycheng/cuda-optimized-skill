{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/diagnostic_measurement.schema.json",
  "title": "CUDA optimizer diagnostic adapter measurement v1",
  "$comment": "The Controller supplies the diagnostic kind. Runtime validation enforces the kind-specific subset of this closed signal vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "subject", "report", "signals", "checks"],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/diagnostic-measurement-v1"},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_sha256"],
      "properties": {
        "target_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_sha256", "events_total"],
      "properties": {
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "events_total": {"type": "integer", "minimum": 1}
      }
    },
    "signals": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "launch_gap_short_context", "gpu_idle_gap", "cpu_launch_overhead",
          "gqa_head_ratio", "shape_fragmentation", "framework_dispatch_overhead"
        ]
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": {"$ref": "#/$defs/identifier"},
          "passed": {"const": true}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"}
  }
}

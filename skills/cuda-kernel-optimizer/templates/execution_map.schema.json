{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v3.1/execution-map.json",
  "title": "CUDA optimizer V3.1 epoch-bound execution map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "map_id",
    "epoch_id",
    "epoch_sha256",
    "identities",
    "window",
    "coverage",
    "nodes",
    "edges",
    "hot_path",
    "uncovered_intervals",
    "conclusion_level"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/execution-map-v1"},
    "map_id": {"$ref": "#/$defs/identifier"},
    "epoch_id": {"$ref": "#/$defs/identifier"},
    "epoch_sha256": {"$ref": "#/$defs/sha256"},
    "identities": {"$ref": "#/$defs/identities"},
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_us", "end_us", "boundary_ambiguous"],
      "properties": {
        "start_us": {"type": "number", "minimum": 0},
        "end_us": {"type": "number", "exclusiveMinimum": 0},
        "boundary_ambiguous": {"type": "boolean"}
      }
    },
    "coverage": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "status", "reason"],
        "properties": {
          "layer": {"$ref": "#/$defs/layer"},
          "status": {"enum": ["observed", "not_observed", "unavailable"]},
          "reason": {
            "oneOf": [
              {"type": "string", "minLength": 1, "maxLength": 512},
              {"type": "null"}
            ]
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "layer",
          "lane",
          "kind",
          "label",
          "duration_us",
          "occurrences",
          "attribution_status",
          "evidence_ids"
        ],
        "properties": {
          "node_id": {"$ref": "#/$defs/identifier"},
          "layer": {"$ref": "#/$defs/layer"},
          "lane": {"$ref": "#/$defs/identifier"},
          "kind": {"$ref": "#/$defs/identifier"},
          "label": {"type": "string", "minLength": 1, "maxLength": 512},
          "duration_us": {"type": "number", "exclusiveMinimum": 0},
          "occurrences": {"type": "integer", "minimum": 1},
          "attribution_status": {
            "enum": ["explained", "unexplained", "not_applicable"]
          },
          "evidence_ids": {"$ref": "#/$defs/evidence_ids"}
        }
      }
    },
    "edges": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "relation", "evidence_ids"],
        "properties": {
          "source": {"$ref": "#/$defs/identifier"},
          "target": {"$ref": "#/$defs/identifier"},
          "relation": {
            "enum": [
              "calls",
              "waits_for",
              "transfers_to",
              "synchronizes",
              "precedes",
              "unknown_dependency"
            ]
          },
          "evidence_ids": {"$ref": "#/$defs/evidence_ids"}
        }
      }
    },
    "hot_path": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "uncovered_intervals": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start_us", "end_us", "reason"],
        "properties": {
          "start_us": {"type": "number", "minimum": 0},
          "end_us": {"type": "number", "exclusiveMinimum": 0},
          "reason": {"type": "string", "minLength": 1, "maxLength": 512}
        }
      }
    },
    "conclusion_level": {"enum": ["observed", "inconclusive"]}
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "layer": {
      "enum": [
        "cpu",
        "gpu",
        "framework",
        "transfer",
        "communication",
        "io",
        "synchronization",
        "idle"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "identities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload_contract_sha256",
        "environment_sha256",
        "source_sha256",
        "analysis_policy_sha256"
      ],
      "properties": {
        "workload_contract_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "analysis_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

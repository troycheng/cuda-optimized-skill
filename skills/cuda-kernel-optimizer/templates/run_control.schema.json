{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/run_control.schema.json",
  "title": "CUDA optimizer deterministic run-control state v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "contract_sha256",
    "started_at",
    "updated_at",
    "max_seconds",
    "max_candidates",
    "max_evidence_age_seconds",
    "objective_metric",
    "objective_direction",
    "mutation_paths",
    "candidates_started",
    "active_candidate",
    "candidate_history",
    "champion_candidate_id",
    "environment_state",
    "measurable",
    "stop_reason",
    "drift_reason",
    "audit_reason"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/run-control-v1"},
    "phase": {"enum": ["INIT", "FROZEN", "CALIBRATING", "EXPLORING", "AUDITING", "DRIFTED", "CONVERGING", "STOPPED"]},
    "contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "started_at": {"type": "number", "minimum": 0},
    "updated_at": {"type": "number", "minimum": 0},
    "max_seconds": {"type": "number", "exclusiveMinimum": 0},
    "max_candidates": {"type": "integer", "minimum": 1},
    "max_evidence_age_seconds": {"type": "number", "exclusiveMinimum": 0},
    "objective_metric": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "objective_direction": {"enum": ["lower", "higher"]},
    "mutation_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
    },
    "candidates_started": {"type": "integer", "minimum": 0},
    "active_candidate": {"type": ["object", "null"]},
    "candidate_history": {"type": "array", "items": {"type": "object"}},
    "champion_candidate_id": {"type": ["string", "null"]},
    "environment_state": {"enum": ["green", "yellow", "red", null]},
    "measurable": {"type": ["boolean", "null"]},
    "stop_reason": {"type": ["string", "null"]},
    "drift_reason": {"type": ["string", "null"]},
    "audit_reason": {"type": ["string", "null"]}
  }
}

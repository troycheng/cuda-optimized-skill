{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/gate_measurement.schema.json",
  "title": "CUDA optimizer raw gate adapter measurement v1",
  "$comment": "Controller selects the adapter kind outside this document. oneOf infers the closed shape from kind-specific subject/result fields. Cross-field equality such as cases_passed == cases_total remains a runtime-only invariant.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "subject", "result", "checks"],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/gate-measurement-v1"},
    "subject": {"type": "object"},
    "result": {"type": "object"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": {"$ref": "#/$defs/identifier"},
          "passed": {"const": true}
        }
      }
    }
  },
  "oneOf": [
    {
      "title": "correctness_reference",
      "properties": {
        "subject": {
          "additionalProperties": false,
          "required": ["reference_sha256"],
          "properties": {"reference_sha256": {"$ref": "#/$defs/sha256"}}
        },
        "result": {
          "additionalProperties": false,
          "required": ["oracle_sha256", "cases_total"],
          "properties": {
            "oracle_sha256": {"$ref": "#/$defs/sha256"},
            "cases_total": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    {
      "title": "dispatch_identity",
      "properties": {
        "subject": {
          "additionalProperties": false,
          "required": ["target_sha256"],
          "properties": {"target_sha256": {"$ref": "#/$defs/sha256"}}
        },
        "result": {
          "additionalProperties": false,
          "required": ["dispatch_sha256", "cases_total"],
          "properties": {
            "dispatch_sha256": {"$ref": "#/$defs/sha256"},
            "cases_total": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    {
      "title": "target_compile_probe",
      "properties": {
        "subject": {
          "additionalProperties": false,
          "required": ["target_sha256"],
          "properties": {"target_sha256": {"$ref": "#/$defs/sha256"}}
        },
        "result": {
          "additionalProperties": false,
          "required": ["arch", "binary_sha256", "compiler_sha256"],
          "properties": {
            "arch": {"type": "string", "pattern": "^sm_[0-9]+$"},
            "binary_sha256": {"$ref": "#/$defs/sha256"},
            "compiler_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      }
    },
    {
      "title": "candidate_correctness",
      "properties": {
        "subject": {"$ref": "#/$defs/candidateSubject"},
        "result": {
          "additionalProperties": false,
          "required": ["reference_sha256", "cases_total", "cases_passed"],
          "properties": {
            "reference_sha256": {"$ref": "#/$defs/sha256"},
            "cases_total": {"type": "integer", "minimum": 1},
            "cases_passed": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    {
      "title": "paired_measurement",
      "properties": {
        "subject": {"$ref": "#/$defs/candidateSubject"},
        "result": {
          "additionalProperties": false,
          "required": ["samples_sha256", "pairs_total", "decision"],
          "properties": {
            "samples_sha256": {"$ref": "#/$defs/sha256"},
            "pairs_total": {"type": "integer", "minimum": 1},
            "decision": {"const": "PASS"}
          }
        }
      }
    },
    {
      "title": "workload_replay",
      "properties": {
        "subject": {"$ref": "#/$defs/candidateSubject"},
        "result": {
          "additionalProperties": false,
          "required": ["workload_sha256", "constraints_passed", "objective_gate_passed"],
          "properties": {
            "workload_sha256": {"$ref": "#/$defs/sha256"},
            "constraints_passed": {"const": true},
            "objective_gate_passed": {"const": true}
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "candidateSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "candidate_sha256"],
      "properties": {
        "candidate_id": {"$ref": "#/$defs/identifier"},
        "candidate_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}

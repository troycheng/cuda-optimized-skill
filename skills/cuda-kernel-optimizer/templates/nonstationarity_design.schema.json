{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel-flow.dev/cuda-kernel-optimizer/v2.8/nonstationarity_design.schema.json",
  "title": "Frozen nonstationarity experiment design",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "metric", "measurement", "assignment_method", "blocks", "state_dimensions"],
  "properties": {
    "schema_version": {"const": 1},
    "metric": {"$ref": "#/$defs/metric"},
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "minimum_duration_ms", "maximum_duration_ms", "burn_in_rows_per_segment", "minimum_complete_blocks"],
      "properties": {
        "mode": {"enum": ["time_windows", "count_windows"]},
        "minimum_duration_ms": {"type": "number", "exclusiveMinimum": 0},
        "maximum_duration_ms": {"type": "number", "exclusiveMinimum": 0},
        "burn_in_rows_per_segment": {"type": "integer", "minimum": 1},
        "minimum_complete_blocks": {"type": "integer", "minimum": 4}
      }
    },
    "assignment_method": {"const": "site_randomized_balanced"},
    "blocks": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["block_id", "order"],
        "properties": {
          "block_id": {"$ref": "#/$defs/identifier"},
          "order": {"enum": ["AB", "BA"]}
        }
      }
    },
    "state_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "epsilon", "pair_max_absolute", "pair_max_percent", "phase_max_absolute", "phase_max_percent"],
        "properties": {
          "name": {"$ref": "#/$defs/identifier"},
          "unit": {"$ref": "#/$defs/identifier"},
          "epsilon": {"type": "number", "exclusiveMinimum": 0},
          "pair_max_absolute": {"$ref": "#/$defs/nullable_nonnegative"},
          "pair_max_percent": {"$ref": "#/$defs/nullable_nonnegative"},
          "phase_max_absolute": {"$ref": "#/$defs/nullable_nonnegative"},
          "phase_max_percent": {"$ref": "#/$defs/nullable_nonnegative"}
        },
        "allOf": [
          {"anyOf": [{"required": ["pair_max_absolute"], "properties": {"pair_max_absolute": {"type": "number"}}}, {"required": ["pair_max_percent"], "properties": {"pair_max_percent": {"type": "number"}}}]},
          {"anyOf": [{"required": ["phase_max_absolute"], "properties": {"phase_max_absolute": {"type": "number"}}}, {"required": ["phase_max_percent"], "properties": {"phase_max_percent": {"type": "number"}}}]}
        ]
      }
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "nullable_nonnegative": {"type": ["number", "null"], "minimum": 0},
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "direction"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "unit": {"$ref": "#/$defs/identifier"},
        "direction": {"enum": ["lower", "higher"]}
      }
    }
  }
}

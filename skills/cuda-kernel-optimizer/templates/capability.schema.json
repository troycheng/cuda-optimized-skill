{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/capability.schema.json",
  "title": "CUDA optimizer capability metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "version", "status", "task", "layer", "axes", "architectures",
    "required_features", "frameworks", "signal_groups", "counter_signals_any",
    "requires_evidence", "gate_requirements", "contract_binding_required", "conflicts", "context_cost_bytes", "playbook",
    "playbook_sha256", "source_ids", "last_reviewed", "risk", "method_ids"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}$"},
    "status": {"enum": ["experimental", "verified", "deprecated"]},
    "task": {"type": "string", "minLength": 1},
    "layer": {"type": "string", "minLength": 1},
    "axes": {"$ref": "#/$defs/nonemptyStrings"},
    "architectures": {"$ref": "#/$defs/nonemptyStrings"},
    "required_features": {"$ref": "#/$defs/strings"},
    "frameworks": {
      "type": "object",
      "propertyNames": {"minLength": 1},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["min_inclusive", "max_exclusive"],
        "properties": {
          "min_inclusive": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){0,3}$"},
          "max_exclusive": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){0,3}$"}
        }
      }
    },
    "signal_groups": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonemptyStrings"}
    },
    "counter_signals_any": {"$ref": "#/$defs/strings"},
    "requires_evidence": {"$ref": "#/$defs/strings"},
    "gate_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pre_execution", "promotion"],
      "properties": {
        "pre_execution": {
          "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
          "items": {"enum": ["correctness_reference", "dispatch_identity", "target_compile_probe"]}
        },
        "promotion": {
          "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
          "items": {"enum": ["candidate_correctness", "paired_measurement", "workload_replay"]}
        }
      }
    },
    "contract_binding_required": {"const": true},
    "conflicts": {"$ref": "#/$defs/strings"},
    "context_cost_bytes": {"type": "integer", "minimum": 1},
    "playbook": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.md$"},
    "playbook_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_ids": {"$ref": "#/$defs/nonemptyStrings"},
    "last_reviewed": {"type": "string", "format": "date"},
    "risk": {"enum": ["low", "medium", "high"]},
    "method_ids": {"$ref": "#/$defs/strings"}
  },
  "$defs": {
    "strings": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "nonemptyStrings": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schema/v2.6/performance-iteration.json",
  "title": "Performance-first iteration record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "round_id",
    "lineage_id",
    "hypothesis",
    "budget",
    "measurement_path",
    "baseline",
    "candidate",
    "correctness",
    "performance"
  ],
  "properties": {
    "schema_version": {"const": "cuda-optimizer/performance-iteration-v1"},
    "round_id": {"type": "string", "minLength": 1},
    "lineage_id": {"type": "string", "minLength": 1},
    "hypothesis": {"$ref": "#/$defs/hypothesis"},
    "budget": {"$ref": "#/$defs/budget"},
    "measurement_path": {"$ref": "#/$defs/roundPath"},
    "baseline": {"$ref": "#/$defs/baseline"},
    "candidate": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/candidate"}]
    },
    "correctness": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/correctness"}]
    },
    "performance": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/completedPerformance"},
        {"$ref": "#/$defs/failedPerformance"}
      ]
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "safePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "pathIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "definition_sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "definition_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "roundPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "definition_sha256", "registry_sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "definition_sha256": {"$ref": "#/$defs/sha256"},
        "registry_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "mechanism",
        "target_metric",
        "direction",
        "minimum_effect_pct",
        "mutation_scope"
      ],
      "properties": {
        "statement": {"type": "string", "minLength": 12},
        "mechanism": {"type": "string", "minLength": 1},
        "target_metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["lower", "higher"]},
        "minimum_effect_pct": {"type": "number", "exclusiveMinimum": 0},
        "mutation_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["round_seconds", "infrastructure_seconds", "infrastructure_repairs"],
      "properties": {
        "round_seconds": {"type": "number", "exclusiveMinimum": 0},
        "infrastructure_seconds": {"type": "number", "minimum": 0},
        "infrastructure_repairs": {"type": "integer", "minimum": 0}
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_sha256", "environment_sha256"],
      "properties": {
        "snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "baseline_snapshot_sha256",
        "candidate_snapshot_sha256",
        "environment_sha256",
        "mechanism",
        "changed_paths"
      ],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "baseline_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "mechanism": {"type": "string", "minLength": 1},
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        }
      }
    },
    "boundIdentity": {
      "type": "object",
      "required": [
        "baseline_snapshot_sha256",
        "candidate_snapshot_sha256",
        "environment_sha256",
        "measurement_path"
      ],
      "properties": {
        "baseline_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_path": {"$ref": "#/$defs/pathIdentity"}
      }
    },
    "correctness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "baseline_snapshot_sha256",
        "candidate_snapshot_sha256",
        "environment_sha256",
        "measurement_path"
      ],
      "properties": {
        "status": {"enum": ["passed", "failed"]},
        "baseline_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_path": {"$ref": "#/$defs/pathIdentity"}
      }
    },
    "completedPerformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "verdict",
        "target_metric",
        "direction",
        "minimum_effect_pct",
        "estimate_pct",
        "ci_low_pct",
        "ci_high_pct",
        "baseline_snapshot_sha256",
        "candidate_snapshot_sha256",
        "environment_sha256",
        "measurement_path"
      ],
      "properties": {
        "status": {"const": "completed"},
        "verdict": {"enum": ["confirmed_win", "confirmed_loss", "inconclusive"]},
        "target_metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["lower", "higher"]},
        "minimum_effect_pct": {"type": "number", "exclusiveMinimum": 0},
        "estimate_pct": {"type": "number"},
        "ci_low_pct": {"type": "number"},
        "ci_high_pct": {"type": "number"},
        "baseline_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_path": {"$ref": "#/$defs/pathIdentity"}
      }
    },
    "failedPerformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "error",
        "target_metric",
        "direction",
        "baseline_snapshot_sha256",
        "candidate_snapshot_sha256",
        "environment_sha256",
        "measurement_path"
      ],
      "properties": {
        "status": {"const": "failed"},
        "error": {"type": "string", "minLength": 1},
        "target_metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["lower", "higher"]},
        "baseline_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "environment_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_path": {"$ref": "#/$defs/pathIdentity"}
      }
    }
  }
}

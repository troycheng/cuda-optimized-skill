{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/troycheng/cuda-optimized-skill/schemas/v2.5/execution-path.json",
  "title": "CUDA optimizer V2.5 execution-path coverage proof",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "expected_cases", "case_hits", "proof_kind", "trace_sha256", "diagnostic_binary", "timed_binary", "rebuilt_after_diagnostics", "timed_binary_bound"],
  "properties": {
    "schema_version": {"const": "cuda-evidence/execution-path-v1"},
    "expected_cases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "case_hits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "hit_count"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "hit_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "proof_kind": {"enum": ["dispatch_counter", "trace", "topology"]},
    "trace_sha256": {"$ref": "#/$defs/sha256"},
    "diagnostic_binary": {"$ref": "#/$defs/binary"},
    "timed_binary": {"$ref": "#/$defs/binary"},
    "rebuilt_after_diagnostics": {"const": true},
    "timed_binary_bound": {"const": true}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "binary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "source_sha256", "build_config_sha256", "diagnostic_features"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "build_config_sha256": {"$ref": "#/$defs/sha256"},
        "diagnostic_features": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
